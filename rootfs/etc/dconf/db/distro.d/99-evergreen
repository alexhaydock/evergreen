# dconf overrides in distro.d get evaluated in order so we
# use 99 here as the prefix to ensure that any settings we
# set override the imported Bluefin defaults if they overlap

# /etc/dconf/db/distro.d/99-evergreen

[org/gnome/desktop/background]
color-shading-type='solid'
picture-options='zoom'
picture-uri='file:///usr/share/backgrounds/gnome/progress-l.jxl'
picture-uri-dark='file:///usr/share/backgrounds/gnome/progress-d.jxl'
primary-color='#967864'
secondary-color='#000000'

# Set UK keyboard. Extra useful as the installer we get
# with build-iso defaults to only installing in US mode
# and this isn't selectable during installation.
[org/gnome/desktop/input-sources]
sources=[('xkb', 'gb')]
current=0

[org/gnome/desktop/interface]
accent-color='teal'
clock-format='12h'
clock-show-weekday=true
color-scheme='prefer-dark'
enable-hot-corners=true
show-battery-percentage=true

[org/gnome/desktop/notifications]
show-in-lock-screen=false

[org/gnome/desktop/peripherals/touchpad]
tap-to-click=true

[org/gnome/desktop/privacy]
remember-recent-files=false
remove-old-temp-files=true
remove-old-trash-files=true
report-technical-problems=false

[org/gnome/desktop/screensaver]
color-shading-type='solid'
picture-options='zoom'
picture-uri='file:///usr/share/backgrounds/gnome/progress-l.jxl'
picture-uri-dark='file:///usr/share/backgrounds/gnome/progress-d.jxl'
primary-color='#967864'
secondary-color='#000000'

[org/gnome/gnome-system-monitor]
graph-update-interval=3000
network-in-bits=true
resources-memory-in-iec=true
show-whose-processes='all'

[org/gnome/nautilus/icon-view]
default-zoom-level='large'

[org/gnome/nautilus/preferences]
recursive-search='always'
show-image-thumbnails='always'

[org/gnome/Ptyxis]
default-columns=uint32 120
default-rows=uint32 36

[org/gnome/Ptyxis/Profiles/2871e8027773ae74d6c87a5f659bbc74]
palette='catppuccin-dynamic'

[org/gnome/settings-daemon/plugins/color]
night-light-enabled=true
night-light-temperature=3700

[org/gnome/settings-daemon/plugins/power]
ambient-enabled=false
sleep-inactive-ac-type='suspend'
sleep-inactive-ac-timeout=3600

[org/gnome/shell]
allow-extension-installation=false
favorite-apps=['io.gitlab.librewolf-community.desktop', 'org.gnome.Nautilus.desktop', 'org.signal.Signal.desktop', 'im.riot.Riot.desktop', 'org.jeffvli.feishin.desktop', 'md.obsidian.Obsidian.desktop', 'com.vscodium.codium.desktop', 'com.bitwarden.desktop.desktop', 'org.gnome.SystemMonitor.desktop', 'org.gnome.Ptyxis.desktop']
enabled-extensions=['']

[org/gnome/system/location]
enabled=false

[org/gnome/TextEditor]
restore-session=false
