# Podman API service socket
# Listens on /run/podman/podman.sock
# Enabled as a socket as we don't need the API service all the time
enable podman.socket

# Enable the socket-activated polkit-agent-helper
# which allows us to run without SUID
# See: https://github.com/polkit-org/polkit/commit/c007940054392b67b84b6044dda8a215040d8eb5
enable polkit-agent-helper.socket

# Enable SSH, but socket activated so it's not
# always running
enable sshd.socket
