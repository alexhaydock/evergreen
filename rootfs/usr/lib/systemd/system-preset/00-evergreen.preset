# Podman service
enable podman.socket

# Podman auto update timer
enable podman-auto-update.timer

# Evergreen "declarative-ish" services
enable dconf-update.service
enable flatpak-preinstall.service

# Universal Blue upstream setup service (System-level)
enable ublue-system-setup.service

# Firmware updater
enable fwupd.service

# Smartcard daemon for age-plugin-yubikey
enable pcscd.service

# Disable the old rpm-ostree timer if it exists
disable rpm-ostreed-automatic.timer
